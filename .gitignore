# ───────── Python / backend ─────────
backend/venv/
__pycache__/
*.pyc

# Vector DB — regenerable via `python ingest.py` (large binary, do not commit)
backend/chroma_db/
backend/chroma_db.bak/

# Cloned TM Forum repos — re-fetched by ingest.py; contain nested .git repos (~333MB)
backend/data/

# Runtime state + user uploads (recreated from defaults in main.py)
backend/storage/*.json
backend/uploads/

# ───────── Frontend / Next.js ─────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.env*.local

# ───────── Logs / OS / editor junk ─────────
*.log
.DS_Store

# Local editor / tooling config (machine-specific paths)
.claude/
.vscode/
.idea/
